{
    "name": "serverless-dynamodb",
    "version": "0.2.57",
    "description": "Serverless plugin to run DynamoDB local",
    "license": "MIT",
    "author": "Adam Jones (domdomegg)",
    "repository": {
        "type": "git",
        "url": "https://github.com/raisenational/serverless-dynamodb"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest --watch",
        "lint": "eslint --ext .js,.jsx,.ts,.tsx .",
        "lint:fix": "eslint --fix --ext .js,.jsx,.ts,.tsx .",
        "clean": "rm -rf dist",
        "build": "tsc --project tsconfig.build.json",
        "prepublishOnly": "npm run clean && npm run build"
    },
    "dependencies": {
        "@aws-sdk/client-dynamodb": "^3.474.0",
        "@aws-sdk/lib-dynamodb": "^3.474.0",
        "aws-dynamodb-local": "^0.0.14"
    },
    "devDependencies": {
        "@tsconfig/node-lts": "^20.1.3",
        "@tsconfig/strictest": "^2.0.8",
        "@types/node": "^20.14.8",
        "@types/serverless": "^3.12.27",
        "eslint": "^9.39.2",
        "eslint-config-domdomegg": "^2.0.9",
        "typescript": "^5.9.3",
        "vitest": "^4.0.17"
    },
    "keywords": [
        "serverless framework plugin",
        "serverless applications",
        "serverless plugins",
        "api gateway",
        "lambda",
        "dynamodb",
        "dynamodb local",
        "aws",
        "aws lambda",
        "aws dynamodb",
        "amazon",
        "amazon web services",
        "serverless.com"
    ]
}
